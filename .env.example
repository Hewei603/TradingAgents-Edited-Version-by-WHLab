# Copy this file to .env and fill only the providers you use.

# LLM providers
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Market data fallback
ALPHA_VANTAGE_API_KEY=

# Optional provider/runtime settings
OLLAMA_BASE_URL=http://localhost:11434/v1
TRADINGAGENTS_LLM_PROVIDER=openai
TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
TRADINGAGENTS_OUTPUT_LANGUAGE=English
TRADINGAGENTS_TEMPERATURE=
TRADINGAGENTS_CHECKPOINT_ENABLED=false

# Optional local paths
TRADINGAGENTS_RESULTS_DIR=reports
TRADINGAGENTS_CACHE_DIR=.cache/tradingagents
TRADINGAGENTS_MEMORY_LOG_PATH=.cache/tradingagents/trading_memory.md
